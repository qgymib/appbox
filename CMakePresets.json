{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 15,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "RelWithDebInfo",
      "binaryDir": "${sourceDir}/build/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "RelWithDebInfo",
      "configurePreset": "RelWithDebInfo",
      "configuration": "RelWithDebInfo",
      "jobs": 8
    }
  ],
  "testPresets": [
    {
      "name": "RelWithDebInfo",
      "configurePreset": "RelWithDebInfo",
      "configuration": "RelWithDebInfo",
      "environment": {
        "APPBOX_LOG_LEVEL": "info"
      },
      "output": {
        "outputOnFailure": true,
        "verbosity": "verbose"
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "RelWithDebInfo",
      "steps": [
        {
          "type": "configure",
          "name": "RelWithDebInfo"
        },
        {
          "type": "build",
          "name": "RelWithDebInfo"
        },
        {
          "type": "test",
          "name": "RelWithDebInfo"
        }
      ]
    }
  ]
}